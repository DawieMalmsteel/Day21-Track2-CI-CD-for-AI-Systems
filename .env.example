# .env.example
# Safe local environment variables for development (no cloud credentials).
# Copy this to .env and edit locally. Do NOT commit secrets.

# MLflow (local sqlite + local artifact root)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlartifacts

# App/server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENV=development

# Training/eval thresholds
EVAL_THRESHOLD=0.70

# DVC / remote placeholders (leave empty here; configure remote securely outside repo)
# DVC_REMOTE_URL=
# DVC_REMOTE_USER=

# Cloud credentials should NEVER be stored in repo files. Use CI/CD secret store or local
# environment variables not committed to version control, e.g. GOOGLE_APPLICATION_CREDENTIALS,
# AWS_ACCESS_KEY_ID, GCS_BUCKET, etc. (keep them out of this file)
